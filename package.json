{
  "name": "xstate-component-tree",
  "version": "9.0.0",
  "description": "Build a tree of components based on statechart values",
  "author": "Pat Cavit <npm@patcavit.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:clean": "shx rm -rf dist/*",
    "build:copy": "shx mkdir -p dist && shx cp src/* dist",
    "build:types": "tsc",
    "build:cleantypes": "shx rm dist/*.d.ts",
    "build": "npm-run-all build:clean --parallel build:copy build:types",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test",
    "test:coverage": "c8 --check-coverage --100 --reporter=html --reporter=text node --test",
    "test:report": "c8 report --reporter=text-lcov > coverage/tests.lcov",
    "test:watch": "chokidar \"**/*.js\" -c \"npm test\"",
    "types": "tsc",
    "prerelease": "npm run test && npm run build",
    "release": "changeset publish",
    "postrelease": "git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tivac/xstate-component-tree.git"
  },
  "keywords": [
    "xstate",
    "components",
    "statecahart"
  ],
  "files": [
    "dist/"
  ],
   "exports": {
    ".": "./dist/component-tree.js",
    "./from-machine": "./dist/from-machine.js",
    "./component-helper": "./dist/component-helper.js"
  },
  "module": "dist/component-tree.js",
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "c8": "^11.0.0",
    "chokidar-cli": "^3.0.0",
    "dedent": "^1.7.2",
    "eslint": "^10.3.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "nanospy": "^1.0.0",
    "npm-run-all": "^4.1.5",
    "object-inspect": "^1.13.4",
    "shx": "^0.4.0",
    "strip-ansi": "^7.2.0",
    "typescript": "^6.0.3",
    "uvu": "^0.5.6",
    "xstate": "^5.19.1"
  },
  "peerDependencies": {
    "xstate": "^5"
  }
}
